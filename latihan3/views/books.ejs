<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Daftar Buku</title>
  <script src="https://unpkg.com/@tailwindcss/browser@4"></script>
</head>
<body class="bg-gray-100 text-gray-800 font-sans p-6">
  <div class="max-w-4xl mx-auto">
    <!-- Header Navigation -->
    <div class="flex justify-between items-center mb-6">
      <h1 class="text-3xl font-bold text-blue-600">📚 Katalog Buku & Penulis</h1>
    </div>

    <div class="flex gap-2 mb-6">
      <a href="/" class="px-4 py-2 bg-white text-gray-700 border rounded-lg font-medium hover:bg-gray-50">Tampilkan Semua</a>
      <a href="/books" class="px-4 py-2 bg-blue-600 text-white rounded-lg font-medium shadow">Daftar Buku</a>
      <a href="/authors" class="px-4 py-2 bg-white text-gray-700 border rounded-lg font-medium hover:bg-gray-50">Daftar Penulis</a>
    </div>

    <div class="bg-white p-6 rounded-lg shadow-md">
      <h2 class="text-xl font-semibold mb-4 text-blue-600 border-b pb-2">Daftar Buku</h2>
      
      <ul class="space-y-3">
        <% books.forEach(book => { %>
          <li class="p-4 bg-gray-50 rounded-lg border border-gray-200 flex justify-between items-center">
            <span class="font-bold text-gray-800 text-lg"><%= book.title %></span>
            
            <div class="flex gap-2">
              <a href="/edit/<%= book.id %>" class="px-3.5 py-1.5 text-xs bg-amber-500 text-white rounded-md hover:bg-amber-600 font-medium flex items-center">
                Edit
              </a>
              <a href="/hapus/<%= book.id %>" class="px-3.5 py-1.5 text-xs bg-red-500 text-white rounded-md hover:bg-red-600 font-medium flex items-center">
                Hapus
              </a>
            </div>
          </li>
        <% }); %>
      </ul>
    </div>
  </div>
</body>
</html>