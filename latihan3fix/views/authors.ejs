<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Daftar Penulis</title>
  <script src="https://unpkg.com/@tailwindcss/browser@4"></script>
</head>
<body class="bg-gray-100 text-gray-800 font-sans p-6">
  <div class="max-w-4xl mx-auto">
    <div class="flex justify-between items-center mb-6">
      <h1 class="text-3xl font-bold text-blue-600">✍️ Daftar Penulis</h1>
      <a href="/" class="px-4 py-2 bg-gray-500 text-white rounded-lg text-sm hover:bg-gray-600">Kembali ke Katalog</a>
    </div>

    <div class="bg-white p-6 rounded-lg shadow-md">
      <!-- Wadah Kosong yang Akan Diisi oleh Fetch JS -->
      <ul id="daftar-penulis-container" class="divide-y divide-gray-200">
        <li class="py-3 px-2 text-gray-500 italic">Memuat data dari API...</li>
      </ul>
    </div>
  </div>

  <!-- SCRIPT FETCH UNTUK MEMANGGIL BACKEND API /api/authors -->
  <script>
    fetch('/api/authors')
      .then(response => response.json())
      .then(dataPenulis => {
        const container = document.getElementById('daftar-penulis-container');
        container.innerHTML = ''; // Hapus pesan loading

        dataPenulis.forEach(author => {
          // Ambil nama penulis (mendukung baik format Object maupun String)
          const namaPenulis = author.name || author;
          const authorId = author.id || encodeURIComponent(namaPenulis);

          // Render item persis sesuai elemen & class CSS awal kamu
          container.innerHTML += `
            <li class="py-3 px-2 flex justify-between items-center hover:bg-gray-50 rounded-lg">
              <span class="text-lg font-medium text-gray-800 flex items-center gap-2">
                👤 ${namaPenulis}
              </span>
              
              <div class="flex gap-2">
                <a href="/edit-author/${authorId}" class="px-3.5 py-1.5 text-xs bg-amber-500 text-white rounded-md hover:bg-amber-600 font-medium">
                  Edit
                </a>
                <a href="/hapus-author/${authorId}" class="px-3.5 py-1.5 text-xs bg-red-500 text-white rounded-md hover:bg-red-600 font-medium">
                  Hapus
                </a>
              </div>
            </li>
          `;
        });
      })
      .catch(error => {
        console.error("Gagal memuat API authors:", error);
        document.getElementById('daftar-penulis-container').innerHTML = `
          <li class="py-3 px-2 text-red-600 font-medium italic">Gagal mengambil data penulis dari server.</li>
        `;
      });
  </script>
</body>
</html>