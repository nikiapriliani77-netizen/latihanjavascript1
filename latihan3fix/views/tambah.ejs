<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tambah Buku</title>
  <script src="https://unpkg.com/@tailwindcss/browser@4"></script>
</head>
<body class="bg-gray-100 text-gray-800 font-sans p-6">
  <div class="max-w-md mx-auto bg-white p-6 rounded-lg shadow-md mt-10">
    <h2 class="text-2xl font-bold mb-6 text-green-600 border-b pb-2">➕ Tambah Buku Baru</h2>
    
    <form action="/tambah" method="POST" class="space-y-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Judul Buku</label>
        <input type="text" name="title" required placeholder="Masukkan judul buku..." class="w-full border rounded p-2 text-sm focus:outline-blue-500">
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Nama Penulis</label>
        <input type="text" name="author" required placeholder="Masukkan nama penulis..." class="w-full border rounded p-2 text-sm focus:outline-blue-500">
      </div>
      <div class="flex justify-between items-center mt-6">
        <a href="/" class="px-4 py-2 bg-gray-300 text-gray-700 rounded text-sm hover:bg-gray-400">Batal</a>
        <button type="submit" class="px-4 py-2 bg-green-600 text-white rounded text-sm hover:bg-green-700 font-medium">Simpan</button>
      </div>
    </form>
  </div>
</body>
</html>